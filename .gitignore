# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# External read-only source notes (vendored to sources/ which IS committed)
input/

# Rendered output — regenerable from scenes/ (keep generators, not videos)
media/

# OS / editor noise
.DS_Store
*.swp
*.swo

# Secrets — projects keep an .env at their root (OPENAI_API_KEY etc.); the
# engine repo itself should never have one, but ignore in case a contributor
# adds one for local experiments. See PIPELINE.md "Environment + secrets".
.env

# Generated site data — embeds the git version, so committing it would go
# stale on every commit. `just web` and the pages.yml deploy regenerate it.
site/data/
