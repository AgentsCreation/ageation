# --- AutoManim project secrets template ----------------------------------
# Copy this file to `<project>/.env` (NOT to the engine root). Per
# PIPELINE.md, `.env` lives at the project root next to `project.yaml`,
# is gitignored, and holds secrets the rendering pipeline needs.
#
# `tools/doctor.py` reads `<project>/.env` (if present) and verifies the
# secrets required by the project's selected voice provider. `make doctor`
# is wired as a prerequisite of every `render*` target, so a missing key
# fails LOUD before manim spins up.

# Required when voice.provider = openai (project.yaml). Leave blank for
# voice.provider = gtts (gTTS is free and needs no key).
OPENAI_API_KEY=

# Optional: alternative TTS providers are not wired yet; add their keys
# here if you patch make_speech_service() to use one.
# AZURE_SPEECH_KEY=
# ELEVENLABS_API_KEY=
